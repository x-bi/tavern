# Tavern Lite Server
# Do not put real API keys in this file.

NODE_ENV=development
SERVER_HOST=127.0.0.1
SERVER_PORT=3100
API_PREFIX=api
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Prisma SQLite database.
# The path is resolved relative to prisma/schema.prisma.
DATABASE_URL="file:../data/tavern-lite.db"

# Stage 7 auth: single-user mode only.
# No-password local admin mode:
AUTH_MODE=single_user
AUTH_REQUIRE_PASSWORD=false
AUTH_SINGLE_USER_USERNAME=demo
AUTH_SINGLE_USER_DISPLAY_NAME="Tavern Admin"

# Enable these for local password protection.
# AUTH_REQUIRE_PASSWORD=true
# AUTH_SINGLE_USER_PASSWORD="change-this-local-password"

# Signed lightweight auth token. Use a long random value outside local dev.
AUTH_TOKEN_SECRET="dev-only-change-me"
AUTH_TOKEN_TTL_SECONDS=604800
