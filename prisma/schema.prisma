generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  displayName  String
  passwordHash String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  appSettings   AppSetting[]
  assets        Asset[]
  characters    Character[]
  conversations Conversation[]
  modelCallLogs ModelCallLog[]
  modelConfigs  ModelConfig[]
  personas      UserPersona[]
  promptPresets PromptPreset[]
  worldBooks    WorldBook[]

  @@index([isActive])
  @@index([deletedAt])
}

model Character {
  id                  String    @id @default(cuid())
  userId              String
  avatarAssetId       String?
  name                String
  description         String    @default("")
  personality         String    @default("")
  scenario            String    @default("")
  firstMessage        String    @default("")
  exampleMessagesJson String?
  metadataJson        String?
  isArchived          Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  avatarAsset   Asset?         @relation("CharacterAvatar", fields: [avatarAssetId], references: [id], onDelete: SetNull)
  conversations Conversation[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  worldBooks    WorldBook[]

  @@index([userId])
  @@index([userId, isArchived])
  @@index([name])
  @@index([deletedAt])
}

model ModelConfig {
  id                String    @id @default(cuid())
  userId            String
  name              String
  provider          String    @default("openai-compatible")
  baseUrl           String
  model             String
  apiKeyCiphertext  String?
  apiKeyMask        String?
  defaultParamsJson String?
  isDefault         Boolean   @default(false)
  isEnabled         Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  conversations Conversation[]
  modelCallLogs ModelCallLog[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, isEnabled])
  @@index([provider])
  @@index([deletedAt])
}

model PromptPreset {
  id             String    @id @default(cuid())
  userId         String
  name           String
  description    String    @default("")
  systemPrompt   String    @default("")
  outputRules    String    @default("")
  parametersJson String?
  metadataJson   String?
  isDefault      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  conversations Conversation[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, isDefault])
  @@index([deletedAt])
}

model UserPersona {
  id           String    @id @default(cuid())
  userId       String
  name         String
  content      String    @default("")
  metadataJson String?
  isDefault    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  conversations Conversation[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, isDefault])
  @@index([deletedAt])
}

model Conversation {
  id             String    @id @default(cuid())
  userId         String
  characterId    String
  modelConfigId  String?
  promptPresetId String?
  personaId      String?
  title          String
  status         String    @default("active")
  metadataJson   String?
  lastMessageAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  character     Character      @relation(fields: [characterId], references: [id], onDelete: Cascade)
  messages      Message[]
  modelCallLogs ModelCallLog[]
  modelConfig   ModelConfig?   @relation(fields: [modelConfigId], references: [id], onDelete: SetNull)
  persona       UserPersona?   @relation(fields: [personaId], references: [id], onDelete: SetNull)
  promptPreset  PromptPreset?  @relation(fields: [promptPresetId], references: [id], onDelete: SetNull)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([characterId, updatedAt])
  @@index([modelConfigId])
  @@index([status])
  @@index([deletedAt])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  role           String
  content        String
  status         String    @default("complete")
  metadataJson   String?
  tokenCount     Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  conversation          Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  requestModelCallLogs  ModelCallLog[] @relation("RequestMessageCallLog")
  responseModelCallLogs ModelCallLog[] @relation("ResponseMessageCallLog")

  @@index([conversationId, createdAt])
  @@index([role])
  @@index([status])
}

model WorldBook {
  id           String    @id @default(cuid())
  userId       String
  characterId  String?
  name         String
  description  String    @default("")
  isEnabled    Boolean   @default(true)
  scanDepth    Int       @default(6)
  tokenBudget  Int       @default(1000)
  metadataJson String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  character Character?       @relation(fields: [characterId], references: [id], onDelete: SetNull)
  entries   WorldBookEntry[]
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isEnabled])
  @@index([characterId])
  @@index([deletedAt])
}

model WorldBookEntry {
  id                    String    @id @default(cuid())
  worldBookId           String
  title                 String
  content               String
  keywordsJson          String
  secondaryKeywordsJson String?
  isEnabled             Boolean   @default(true)
  priority              Int       @default(0)
  position              String    @default("before_history")
  tokenBudget           Int?
  caseSensitive         Boolean   @default(false)
  metadataJson          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  worldBook WorldBook @relation(fields: [worldBookId], references: [id], onDelete: Cascade)

  @@index([worldBookId, isEnabled])
  @@index([priority])
  @@index([deletedAt])
}

model Asset {
  id           String    @id @default(cuid())
  userId       String
  kind         String
  fileName     String
  originalName String?
  mimeType     String
  extension    String?
  sizeBytes    Int
  storagePath  String
  publicPath   String?
  metadataJson String?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  characterAvatars Character[] @relation("CharacterAvatar")
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
  @@index([createdAt])
  @@index([deletedAt])
}

model AppSetting {
  id        String   @id @default(cuid())
  userId    String?
  scope     String   @default("global")
  key       String
  value     String
  valueType String   @default("string")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scope, key])
  @@index([userId])
}

model ModelCallLog {
  id                String   @id @default(cuid())
  userId            String
  conversationId    String?
  modelConfigId     String?
  requestMessageId  String?
  responseMessageId String?
  provider          String
  model             String
  status            String
  promptTokens      Int?
  completionTokens  Int?
  totalTokens       Int?
  latencyMs         Int?
  errorCode         String?
  errorMessage      String?
  requestJson       String?
  responseJson      String?
  createdAt         DateTime @default(now())

  conversation    Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  modelConfig     ModelConfig?  @relation(fields: [modelConfigId], references: [id], onDelete: SetNull)
  requestMessage  Message?      @relation("RequestMessageCallLog", fields: [requestMessageId], references: [id], onDelete: SetNull)
  responseMessage Message?      @relation("ResponseMessageCallLog", fields: [responseMessageId], references: [id], onDelete: SetNull)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([modelConfigId])
  @@index([requestMessageId])
  @@index([responseMessageId])
  @@index([status])
}
